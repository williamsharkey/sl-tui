{
  "name": "sl-tui",
  "version": "0.2.0",
  "description": "Terminal-based Second Life client with 3D rendering, chat, and instant messaging",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/williamsharkey/sl-tui.git"
  },
  "keywords": [
    "second-life",
    "tui",
    "terminal",
    "3d",
    "voxel",
    "metaverse",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "sl-tui": "./bin/sl-tui.js"
  },
  "files": [
    "bin/",
    "tui/",
    "server/",
    "vendor/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx --watch tui/main.ts",
    "start": "node --import tsx/esm tui/main.ts",
    "build:ts": "tsc",
    "test": "node --import tsx/esm test/tui-unit.ts && node --import tsx/esm test/tui-integration.ts",
    "bench": "node --import tsx/esm test/bench.ts",
    "prepublishOnly": "npm test"
  },
  "dependencies": {
    "@caspertech/llsd": "^1.0.5",
    "chalk": "^4.1.2",
    "fast-xml-parser": "^4.5.0",
    "flatted": "^3.2.9",
    "fs-extra": "^10.1.0",
    "glob": "^7.2.3",
    "got": "^11.8.6",
    "ipaddr.js": "^2.2.0",
    "logform": "^2.6.0",
    "long": "^4.0.0",
    "micromatch": "^4.0.5",
    "moment": "^2.29.4",
    "qs": "^6.5.3",
    "rbush-3d": "0.0.4",
    "rxjs": "^7.8.1",
    "tiny-async-pool": "^2.1.0",
    "tsx": "^4.19.0",
    "uuid": "^8.3.2",
    "validator": "^13.15.15",
    "winston": "^3.11.0",
    "xml": "^1.0.1",
    "xml2js": "^0.5.0",
    "xmlbuilder": "^15.1.1",
    "xmlrpc": "github:CasperTech/node-xmlrpc"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/long": "^4.0.2",
    "@types/xml": "^1.0.10",
    "@types/xmlrpc": "^1.3.9",
    "@types/xml2js": "^0.4.14",
    "@types/uuid": "^9.0.0",
    "@types/fs-extra": "^11.0.0",
    "@types/qs": "^6.9.0",
    "@types/validator": "^13.0.0",
    "typescript": "^5.6.0"
  }
}
