{
  "name": "sl-tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --watch server/main.ts",
    "build": "tsc",
    "start": "node dist/server/main.js",
    "test": "node --import tsx/esm test/integration.ts",
    "test:live": "node --import tsx/esm test/integration.ts",
    "test:stress": "node --import tsx/esm test/stress.ts",
    "tui": "node --import tsx/esm tui/main.ts",
    "test:tui": "node --import tsx/esm test/tui-unit.ts && node --import tsx/esm test/tui-integration.ts"
  },
  "dependencies": {
    "express": "^4.21.0",
    "ws": "^8.18.0",
    "@caspertech/llsd": "^1.0.5",
    "chalk": "^4.1.2",
    "fast-xml-parser": "^4.5.0",
    "flatted": "^3.2.9",
    "fs-extra": "^10.1.0",
    "glob": "^7.2.3",
    "got": "^11.8.6",
    "ipaddr.js": "^2.2.0",
    "logform": "^2.6.0",
    "long": "^4.0.0",
    "micromatch": "^4.0.5",
    "moment": "^2.29.4",
    "qs": "^6.5.3",
    "rbush-3d": "0.0.4",
    "rxjs": "^7.8.1",
    "tiny-async-pool": "^2.1.0",
    "uuid": "^8.3.2",
    "validator": "^13.15.15",
    "winston": "^3.11.0",
    "xml": "^1.0.1",
    "xml2js": "^0.5.0",
    "xmlbuilder": "^15.1.1",
    "xmlrpc": "github:CasperTech/node-xmlrpc"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.12",
    "@types/node": "^22.0.0",
    "@types/long": "^4.0.2",
    "@types/xml": "^1.0.10",
    "@types/xmlrpc": "^1.3.9",
    "@types/xml2js": "^0.4.14",
    "@types/uuid": "^9.0.0",
    "@types/fs-extra": "^11.0.0",
    "@types/qs": "^6.9.0",
    "@types/validator": "^13.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
